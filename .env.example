# RentTrack — environment variables
# Copy to `.env` (git-ignored) and fill in from your Supabase project:
#   Supabase dashboard → Project Settings → API
#
# EXPO_PUBLIC_* vars are inlined into the app bundle at build time and are
# therefore PUBLIC. Only the anon key belongs here — it is safe to ship because
# Row-Level Security restricts every row to its owner. NEVER put the service-role
# key in this file or anywhere in the client.


EXPO_PUBLIC_SUPABASE_URL=https://bywxdhcjnwatjegnszcd.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_CtRG2DBBYvTnxL_RnYPjPQ_WzUQntmr

# Sentry crash reporting (по избор). Празно = Sentry изключен, приложението
# работи нормално. DSN-ът не е секрет (Sentry docs), но стои тук за конфиг
# на едно място. Взима се от sentry.io -> Project Settings -> Client Keys.
EXPO_PUBLIC_SENTRY_DSN=